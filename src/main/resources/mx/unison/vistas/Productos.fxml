<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
    fx:controller="mx.unison.controladores.ProductosController">
    <Label text="Gestión de Productos" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <TableView fx:id="productosTable" prefHeight="400" prefWidth="800">
        <columns>
            <TableColumn text="ID" fx:id="idColumn"/>
            <TableColumn text="Nombre" fx:id="nombreColumn"/>
            <TableColumn text="Descripción" fx:id="descripcionColumn"/>
            <TableColumn text="Cantidad" fx:id="cantidadColumn"/>
            <TableColumn text="Precio" fx:id="precioColumn"/>
        </columns>
    </TableView>
    <HBox spacing="10" alignment="CENTER">
        <Button text="Agregar" onAction="#handleAdd"/>
        <Button text="Modificar" onAction="#handleEdit"/>
        <Button text="Eliminar" onAction="#handleDelete"/>
        <Button text="Regresar" onAction="#handleGoBack"/>
    </HBox>
</VBox>