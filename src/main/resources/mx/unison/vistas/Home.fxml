<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="mx.unison.controladores.HomeController">
    <Label text="Sistema de Inventario" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
    <Button text="Gestión de Productos" onAction="#handleProductos" style="-fx-padding: 10px;"/>
    <Button text="Gestión de Almacenes" onAction="#handleAlmacenes" style="-fx-padding: 10px;"/>
    <Button text="Cerrar Sesión" onAction="#handleLogout" style="-fx-padding: 10px;"/>
</VBox>